{
    "name": "edutiek/assessment-service",
    "description": "Backend service for long essay assessments",
    "type": "library",
    "license": "GPLv3",
    "version": "0.0.1",
    "autoload": {
        "psr-4": {
            "Edutiek\\AssessmentService\\": "src"
        }
    },
    "authors": [
        {
            "name": "Fred Neumann",
            "email": "neumann@ilias.de"
        },
        {
            "name": "Lukas Scharmer",
            "email": "lscharmer@databay.de"
        },
        {
            "name": "Fabian Wolf",
            "email": "wolf@databay.de"
        }
    ],
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:EDUTIEK/dompdf.git"
        }
    ],
    "require": {
        "php": ">=8.2 <8.5",
        "ext-json": "*",
        "ext-dom": "*",
        "ext-xml": "*",
        "ext-xsl": "*",
        "ext-curl": "*",
        "mustache/mustache": "^2.14",
        "slim/psr7": "^1.7",
        "slim/slim": "^4.14",
        "tecnickcom/tcpdf": "^6.3",
        "yetanotherape/diff-match-patch": "^1.1",
        "phpoffice/phpspreadsheet": "^2.2",
        "dompdf/dompdf": "dev-gs-font-patch",
        "tecnickcom/tc-lib-pdf-parser": "^3.0"
    },
    "minimum-stability": "dev"
}
